                              <div style="height:325px;"><img name="Image101" src="layout/images/mnimeia/zoom/LASKAR251996.jpg" /></div><br/><div style="clear:both;"></div><a href="#" onClick="MM_swapImage('Image101','','layout/images/mnimeia/zoom/LASKAR251996.jpg',1);return false;"><img src="layout/images/mnimeia/LASKAR251996.jpg" /></a>
                           
